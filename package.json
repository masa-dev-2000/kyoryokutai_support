{
  "name": "kyoryokutai-support",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "op:doctor": "node scripts/check-1password-cli.mjs",
    "dev:op": "node scripts/op-run.mjs .env.1password.local npm run dev",
    "dev:op:dev": "node scripts/op-run.mjs .env.1password.dev npm run dev",
    "build": "next build",
    "build:op": "node scripts/op-run.mjs .env.1password.local npm run build",
    "build:static": "BUILD_STATIC=1 next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:op": "node scripts/op-run.mjs .env.1password.local npm run typecheck",
    "db:reset": "rm -rf .data",
    "db:migrate": "tsx scripts/apply-migrations.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
