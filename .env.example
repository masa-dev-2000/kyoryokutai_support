# ===== 実値を置かない公開テンプレート =====
# 秘密情報は 1Password で管理し、実行時は op run --env-file を使う。
# 詳細: docs/27_secure_environment.md

# ===== 実行環境 =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== データベース =====
# sqlite | supabase
DB_PROVIDER=sqlite
DATABASE_PATH=.data/app.db

# ===== 認証 =====
# none | supabase
AUTH_PROVIDER=none
DEMO_USER_ID=m1
DEMO_USER_EMAIL=demo@member.example.jp
NEXT_PUBLIC_DEMO_MEMBER_ID=a1000000-0000-4000-8000-000000000001
NEXT_PUBLIC_DEMO_MUNI_ID=10000000-0000-4000-8000-000000000001

# Supabase(本番/開発接続時)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== AI プロバイダ(差し替え可能 / ADR-016)=====
# mock | ollama | anthropic | bedrock
AI_PROVIDER=mock

# Ollama(ローカル LLM 既定)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Anthropic (Claude API) - AI_PROVIDER=anthropic のとき使用
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# AWS Bedrock - AI_PROVIDER=bedrock のとき使用
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BEDROCK_SONNET_MODEL_ID=anthropic.claude-sonnet-4-6-v1:0
BEDROCK_HAIKU_MODEL_ID=jp.anthropic.claude-haiku-4-5-v1:0
BEDROCK_PROMPT_CACHE=0

# ===== ストレージ =====
# local | r2 | s3 | supabase
STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=.data/storage
STORAGE_REGION=ap-northeast-1
STORAGE_ENDPOINT=
STORAGE_BUCKET=kyoryokutai-receipts
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# R2 互換名も利用可
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# ===== メール =====
# console | smtp
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.jp
SES_FROM_EMAIL=noreply@example.jp
SES_REPLY_TO=
