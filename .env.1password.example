# 1Password env template.
# Copy this file to one of:
#   .env.1password.local
#   .env.1password.dev
#   .env.1password.prod
#
# Then replace op://... references with item/field names from your 1Password vault.
# Do not commit copied files. They are ignored by .gitignore.

# ===== Local defaults: external-service-free development =====
NEXT_PUBLIC_APP_URL=http://localhost:3000

DB_PROVIDER=sqlite
DATABASE_PATH=.data/app.db

AUTH_PROVIDER=none
DEMO_USER_ID=m1
DEMO_USER_EMAIL=demo@member.example.jp
NEXT_PUBLIC_DEMO_MEMBER_ID=a1000000-0000-4000-8000-000000000001
NEXT_PUBLIC_DEMO_MUNI_ID=10000000-0000-4000-8000-000000000001

AI_PROVIDER=mock
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=.data/storage

EMAIL_PROVIDER=console

# ===== Development Supabase/Auth =====
# DB_PROVIDER=supabase
# AUTH_PROVIDER=supabase
# NEXT_PUBLIC_SUPABASE_URL=op://kyoryokutai-support/dev-env/NEXT_PUBLIC_SUPABASE_URL
# NEXT_PUBLIC_SUPABASE_ANON_KEY=op://kyoryokutai-support/dev-env/NEXT_PUBLIC_SUPABASE_ANON_KEY
# SUPABASE_SERVICE_ROLE_KEY=op://kyoryokutai-support/dev-env/SUPABASE_SERVICE_ROLE_KEY

# ===== AI providers =====
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=op://kyoryokutai-support/dev-env/ANTHROPIC_API_KEY
# ANTHROPIC_MODEL=claude-sonnet-4-6
#
# AI_PROVIDER=bedrock
# AWS_REGION=ap-northeast-1
# AWS_ACCESS_KEY_ID=op://kyoryokutai-support/prod-env/AWS_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY=op://kyoryokutai-support/prod-env/AWS_SECRET_ACCESS_KEY
# BEDROCK_SONNET_MODEL_ID=anthropic.claude-sonnet-4-6-v1:0
# BEDROCK_HAIKU_MODEL_ID=jp.anthropic.claude-haiku-4-5-v1:0
# BEDROCK_PROMPT_CACHE=1

# ===== S3-compatible storage: R2/S3/Supabase Storage =====
# STORAGE_PROVIDER=r2
# STORAGE_REGION=auto
# STORAGE_ENDPOINT=op://kyoryokutai-support/prod-env/STORAGE_ENDPOINT
# STORAGE_BUCKET=kyoryokutai-receipts
# STORAGE_ACCESS_KEY_ID=op://kyoryokutai-support/prod-env/STORAGE_ACCESS_KEY_ID
# STORAGE_SECRET_ACCESS_KEY=op://kyoryokutai-support/prod-env/STORAGE_SECRET_ACCESS_KEY

# ===== SMTP email =====
# EMAIL_PROVIDER=smtp
# SMTP_HOST=email-smtp.ap-northeast-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=op://kyoryokutai-support/prod-env/SMTP_USER
# SMTP_PASS=op://kyoryokutai-support/prod-env/SMTP_PASS
# SMTP_FROM=noreply@example.jp
# SES_REPLY_TO=support@example.jp
